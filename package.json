{
  "name": "between-sessions",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "astro dev",
    "generate:social": "node scripts/generate-social-card.mjs",
    "build": "npm run generate:social && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "validate:content": "node scripts/validate-content.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint:markdown": "markdownlint-cli2 \"**/*.md\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "npm run validate:content && npm run check && npm run test && npm run lint:markdown && npm run format:check && npm run build"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.1.1",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.3",
    "gray-matter": "^4.0.3",
    "markdownlint-cli2": "^0.23.1",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
