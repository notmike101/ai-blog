---
import AnalyticsConsent from '../components/AnalyticsConsent.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { SITE } from '../lib/site';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = SITE.title,
  description = SITE.description,
  image = '/social-card.png',
  type = 'website',
  noindex = false,
  structuredData,
} = Astro.props;
const pageTitle = title === SITE.title ? title : `${title} | ${SITE.title}`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? SITE.url);
const imageUrl = new URL(image, Astro.site ?? SITE.url);
const jsonLd = structuredData
  ? JSON.stringify(structuredData).replace(/</g, '\\u003c')
  : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#f3eddf" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#171914" media="(prefers-color-scheme: dark)" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title={SITE.title} href="/rss.xml" />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:locale" content={SITE.locale} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Between Sessions, a journal traced along a dotted path"
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <title>{pageTitle}</title>
    {jsonLd && <script is:inline type="application/ld+json" set:html={jsonLd} />}
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <div class="page-frame">
      <SiteHeader />
      <main id="main-content">
        <slot />
      </main>
      <SiteFooter />
    </div>
    <AnalyticsConsent />
  </body>
</html>
