---
const path = Astro.url.pathname;
const navItems = [
  { href: '/articles/', label: 'Articles' },
  { href: '/categories/', label: 'Categories' },
  { href: '/journey/', label: 'Journey' },
];

const isActive = (href: string) => path === href || path.startsWith(href);
---

<header class="site-header">
  <div class="shell header-inner">
    <a class="wordmark" href="/" aria-label="Between Sessions, home">
      <svg class="wordmark-mark" viewBox="0 0 42 24" aria-hidden="true">
        <path d="M3 15c8-14 18 8 27-3 3-4 5-4 9-3" pathLength="1"></path>
        <circle cx="3" cy="15" r="2.3"></circle>
        <circle cx="39" cy="9" r="2.3"></circle>
      </svg>
      <span>Between Sessions</span>
    </a>
    <nav aria-label="Primary navigation">
      <ul class="nav-list">
        {
          navItems.map(({ href, label }) => (
            <li>
              <a href={href} aria-current={isActive(href) ? 'page' : undefined}>
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
