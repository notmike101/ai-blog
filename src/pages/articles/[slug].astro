---
import { getCollection, type CollectionEntry } from 'astro:content';
import ArticleArchive from '../../components/ArticleArchive.astro';
import ArticleDetail from '../../components/ArticleDetail.astro';
import { sortPosts } from '../../lib/site';

type Props =
  | { kind: 'article'; post: CollectionEntry<'posts'> }
  | { kind: 'archive'; currentPage: number };

export async function getStaticPaths() {
  const posts = sortPosts(await getCollection('posts'));
  const pageCount = Math.ceil(posts.length / 10);
  return [
    ...posts.map((post) => ({
      params: { slug: post.id },
      props: { kind: 'article' as const, post },
    })),
    ...Array.from({ length: Math.max(0, pageCount - 1) }, (_, index) => index + 2).map(
      (currentPage) => ({
        params: { slug: String(currentPage) },
        props: { kind: 'archive' as const, currentPage },
      }),
    ),
  ];
}

const props = Astro.props as Props;
const posts = sortPosts(await getCollection('posts'));
const pageCount = Math.ceil(posts.length / 10);
---

{
  props.kind === 'article' ? (
    <ArticleDetail post={props.post} {posts} />
  ) : (
    <ArticleArchive
      posts={posts.slice((props.currentPage - 1) * 10, props.currentPage * 10)}
      allPosts={posts}
      currentPage={props.currentPage}
      {pageCount}
    />
  )
}
